t_id: recurring.account_id,\n          date: new Date().toISOString(),\n          description: `Płatność cykliczna: ${recurring.name}`,\n          credit_id: recurring.credit_id || null\n        });\n\n        // Update last_executed\n        const index = recurrings.findIndex(r => r.id === id);\n        if (index !== -1) {\n          recurrings[index].last_executed = new Date().toISOString();\n          await setItems(STORAGE_KEYS.RECURRING, recurrings);\n        }\n        return transactionId;\n      }\n    },\n    update: async (id, recurring) => {\n      const recurrings = await getItems(STORAGE_KEYS.RECURRING);\n      const index = recurrings.findIndex(r => r.id === id);\n      if (index !== -1) {\n        recurrings[index] = Object.assign({}, recurrings[index], recurring);\n        await setItems(STORAGE_KEYS.RECURRING, recurrings);\n      }\n    },\n    delete: async id => {\n      const recurrings = await getItems(STORAGE_KEYS.RECURRING);\n      const filtered = recurrings.filter(r => r.id !== id);\n      await setItems(STORAGE_KEYS.RECURRING, filtered);\n    }\n  };\n\n  // Dashboard stats\n  const getDashboardStats = async (month, year) => {\n    const accounts = await accountsDB.getAll();\n    const totalBalance = accounts.reduce((sum, acc) => sum + acc.balance, 0);\n    const now = new Date();\n    const targetMonth = month || now.getMonth() + 1;\n    const targetYear = year || now.getFullYear();\n    const startDate = new Date(targetYear, targetMonth - 1, 1).toISOString();\n    const endDate = new Date(targetYear, targetMonth, 0, 23, 59, 59).toISOString();\n    const incomeTransactions = await transactionsDB.getByDateRange(startDate, endDate, 'income');\n    const expenseTransactions = await transactionsDB.getByDateRange(startDate, endDate, 'expense');\n    const totalIncome = incomeTransactions.reduce((sum, t) => sum + t.amount, 0);\n    const totalExpenses = expenseTransactions.reduce((sum, t) => sum + t.amount, 0);\n    const credits = await creditsDB.getAll();\n    return {\n      total_balance: totalBalance,\n      total_income: totalIncome,\n      total_expenses: totalExpenses,\n      accounts_count: accounts.length,\n      credits_count: credits.length\n    };\n  };\n\n  // Savings Goals\n  const savingsGoalsDB = {\n    getAll: async () => {\n      return await getItems(STORAGE_KEYS.SAVINGS_GOALS);\n    },\n    create: async goal => {\n      const goals = await getItems(STORAGE_KEYS.SAVINGS_GOALS);\n      const id = await generateId();\n      goals.push(Object.assign({}, goal, {\n        id,\n        current_amount: goal.current_amount || 0,\n        created_at: new Date().toISOString()\n      }));\n      await setItems(STORAGE_KEYS.SAVINGS_GOALS, goals);\n      return id;\n    },\n    update: async (id, goal) => {\n      const goals = await getItems(STORAGE_KEYS.SAVINGS_GOALS);\n      const index = goals.findIndex(g => g.id === id);\n      if (index !== -1) {\n        goals[index] = Object.assign({}, goals[index], goal);\n        await setItems(STORAGE_KEYS.SAVINGS_GOALS, goals);\n      }\n    },\n    addAmount: async (id, amount) => {\n      const goals = await getItems(STORAGE_KEYS.SAVINGS_GOALS);\n      const index = goals.findIndex(g => g.id === id);\n      if (index !== -1) {\n        goals[index].current_amount = (goals[index].current_amount || 0) + amount;\n        await setItems(STORAGE_KEYS.SAVINGS_GOALS, goals);\n      }\n    },\n    delete: async id => {\n      const goals = await getItems(STORAGE_KEYS.SAVINGS_GOALS);\n      await setItems(STORAGE_KEYS.SAVINGS_GOALS, goals.filter(g => g.id !== id));\n    }\n  };\n\n  // PIN Management\n  const pinDB = {\n    exists: async () => {\n      const pin = await AsyncStorage.default.getItem(STORAGE_KEYS.PIN_CODE);\n      return !!pin;\n    },\n    set: async pin => {\n      await AsyncStorage.default.setItem(STORAGE_KEYS.PIN_CODE, pin);\n    },\n    verify: async pin => {\n      const stored = await AsyncStorage.default.getItem(STORAGE_KEYS.PIN_CODE);\