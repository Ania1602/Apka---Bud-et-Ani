reated_at: new Date().toISOString()\n      }));\n      await setItems(STORAGE_KEYS.SAVINGS_GOALS, goals);\n      return id;\n    },\n    update: async (id, goal) => {\n      const goals = await getItems(STORAGE_KEYS.SAVINGS_GOALS);\n      const index = goals.findIndex(g => g.id === id);\n      if (index !== -1) {\n        goals[index] = Object.assign({}, goals[index], goal);\n        await setItems(STORAGE_KEYS.SAVINGS_GOALS, goals);\n      }\n    },\n    addAmount: async (id, amount) => {\n      const goals = await getItems(STORAGE_KEYS.SAVINGS_GOALS);\n      const index = goals.findIndex(g => g.id === id);\n      if (index !== -1) {\n        goals[index].current_amount = (goals[index].current_amount || 0) + amount;\n        await setItems(STORAGE_KEYS.SAVINGS_GOALS, goals);\n      }\n    },\n    delete: async id => {\n      const goals = await getItems(STORAGE_KEYS.SAVINGS_GOALS);\n      await setItems(STORAGE_KEYS.SAVINGS_GOALS, goals.filter(g => g.id !== id));\n    }\n  };\n\n  // Investments\n  const investmentsDB = {\n    getAll: async () => {\n      return await getItems(STORAGE_KEYS.INVESTMENTS);\n    },\n    create: async investment => {\n      const items = await getItems(STORAGE_KEYS.INVESTMENTS);\n      const id = await generateId();\n      items.push(Object.assign({}, investment, {\n        id,\n        payments: investment.payments || [],\n        created_at: new Date().toISOString()\n      }));\n      await setItems(STORAGE_KEYS.INVESTMENTS, items);\n      return id;\n    },\n    update: async (id, data) => {\n      const items = await getItems(STORAGE_KEYS.INVESTMENTS);\n      const index = items.findIndex(i => i.id === id);\n      if (index !== -1) {\n        items[index] = Object.assign({}, items[index], data);\n        await setItems(STORAGE_KEYS.INVESTMENTS, items);\n      }\n    },\n    delete: async id => {\n      const items = await getItems(STORAGE_KEYS.INVESTMENTS);\n      await setItems(STORAGE_KEYS.INVESTMENTS, items.filter(i => i.id !== id));\n    },\n    addPayment: async (id, payment) => {\n      const items = await getItems(STORAGE_KEYS.INVESTMENTS);\n      const index = items.findIndex(i => i.id === id);\n      if (index !== -1) {\n        if (!items[index].payments) items[index].payments = [];\n        const paymentId = await generateId();\n        items[index].payments.push(Object.assign({}, payment, {\n          id: paymentId\n        }));\n        items[index].total_paid = (items[index].payments || []).reduce((s, p) => s + (p.amount || 0), 0);\n        await setItems(STORAGE_KEYS.INVESTMENTS, items);\n        return paymentId;\n      }\n    },\n    removePayment: async (investmentId, paymentId) => {\n      const items = await getItems(STORAGE_KEYS.INVESTMENTS);\n      const index = items.findIndex(i => i.id === investmentId);\n      if (index !== -1 && items[index].payments) {\n        items[index].payments = items[index].payments.filter(p => p.id !== paymentId);\n        items[index].total_paid = items[index].payments.reduce((s, p) => s + (p.amount || 0), 0);\n        await setItems(STORAGE_KEYS.INVESTMENTS, items);\n      }\n    },\n    updateValue: async (id, currentValue) => {\n      const items = await getItems(STORAGE_KEYS.INVESTMENTS);\n      const index = items.findIndex(i => i.id === id);\n      if (index !== -1) {\n        items[index].current_value = currentValue;\n        items[index].value_updated_at = new Date().toISOString();\n        await setItems(STORAGE_KEYS.INVESTMENTS, items);\n      }\n    }\n  };\n\n  // User Settings (birth year etc.)\n  const getLastAccountForCategory = async category => {\n    try {\n      const all = await getItems(STORAGE_KEYS.TRANSACTIONS);\n      const matching = all.filter(t => t.category === category && t.account_id).sort((a, b) => new Date(b.created_at || b.date).getTime() - new Date(a.created_at || a.date).getTime());\n      return matching.length > 0 ? matching[0].account_id : null;\n    } catch {\n      return null;\n    }\n  };\n  const userSettingsDB = {\n    get: async key => {\n      try {\n        const val = await AsyncStorage.default.getItem(`@budzetani_setting_${key}`);\n        return val;\n      } catch {\n        return null;\n      }\n    },\n    set: async (key, value) => {\n      try {\n        await AsyncStorage.default.setItem(`@budzetani_setting_${key}`, value);\n      } catch {}\n    }\n  };\n\n  // PIN Management\n  const pinDB = {\n    exists: async () => {\n      const pin = await AsyncStorage.default.getItem(STORAGE_KEYS.PIN_CODE);\n      return !!pin;\n    },\n    set: async pin => {\n      await AsyncStorage.default.setItem(STORAGE_KEYS.PIN_CODE, pin);\n    },\n    verify: async pin => {\n      const stored = await AsyncStorage.default.getItem(STORAGE_KEYS.PIN_CODE);\n      return stored === pin;\n    },\n    remove: async () => {\n      await AsyncStorage.default.removeItem(STORAGE_KEYS.PIN_CODE);\n    }\n  };\n\n  // Dark Mode\n  const darkModeDB = {\n    get: async () => {\n      const val = await AsyncStorage.default.getItem(STORAGE_KEYS.DARK_MODE);\n      return val === 'true';\n    },\n    set: async enabled => {\n      await AsyncStorage.default.setItem(STORAGE_KEYS.DARK_MODE, enabled ? 'true' : 'false');\n    }\n  };\n\n  // Transaction update\n  const transactionUpdate = async (id, updates) => {\n    const transactions = await getItems(STORAGE_KEYS.TRANSACTIONS);\n    const index = transactions.findIndex(t => t.id === id);\n    if (index !== -1) {\n      // Reverse old balance\n      const old = transactions[index];\n      const account = await accountsDB.getById(old.account_id);\n      if (account) {\n        const reversed = old.type === 'income' ? account.balance - old.amount : account.balance + old.amount;\n        await accountsDB.updateBalance(old.account_id, reversed);\n      }\n      // Apply new\n      transactions[index] = Object.assign({}, transactions[index], updates);\n      await setItems(STORAGE_KEYS.TRANSACTIONS, transactions);\n      // Apply new balance\n      const newAcc = await accountsDB.getById(updates.account_id || old.account_id);\n      if (newAcc) {\n        const newBal = (updates.type || old.type) === 'income' ? newAcc.balance + (updates.amount || old.amount) : newAcc.balance - (updates.amount || old.amount);\n        await accountsDB.updateBalance(updates.account_id || old.account_id, newBal);\n      }\n    }\n  };\n\n  // Statistics\n  const getStatistics = async (month, year) => {\n    const startDate = new Date(year, month - 1, 1).toISOString();\n    const endDate = new Date(year, month, 0, 23, 59, 59).toISOString();\n    const allTransactions = await transactionsDB.getByDateRange(startDate, endDate);\n\n    // Exclude transfers from statistics\n    const nonTransferTransactions = allTransactions.filter(t => !t.is_transfer);\n    // Also exclude limit refunds from income stats\n    const statsTransactions = nonTransferTransactions.filter(t => !(t.type === 'income' && t.is_limit_refund));\n    const byCategory = {};\n    statsTransactions.forEach(t => {\n      if (!byCategory[t.category]) byCategory[t.category] = {\n        amount: 0,\n        type: t.type\n      };\n      byCategory[t.category].amount += t.amount;\n    });\n\n    // Monthly trends (last 6 months)\n    const trends = [];\n    for (let i = 5; i >= 0; i--) {\n      const d = new Date(year, month - 1 - i, 1);\n      const ms = d.toISOString();\n      const me = new Date(d.getFullYear(), d.getMonth() + 1, 0, 23, 59, 59).toISOString();\n      const mt = await transactionsDB.getByDateRange(ms, me);\n      const nonTransfer = mt.filter(t => !t.is_transfer);\n      const inc = nonTransfer.filter(t => t.type === 'income' && !t.is_limit_refund).reduce((s, t) => s + t.amount, 0);\n      const exp = nonTransfer.filter(t => t.type === 'expense').reduce((s, t) => s + t.amount, 0);\n      trends.push({\n        month: d.getMonth() + 1,\n        year: d.getFullYear(),\n        income: inc,\n        expenses: exp,\n        label: d.toLocaleDateString('pl-PL', {\n          month: 'short'\n        })\n      });\n    }\n    return {\n      byCategory,\n      trends,\n      totalIncome: statsTransactions.filter(t => t.type === 'income').reduce((s, t) => s + t.amount, 0),\n      totalExpenses: statsTransactions.filter(t => t.type === 'expense').reduce((s, t) => s + t.amount, 0)\n    };\n  };\n\n  // Export to CSV\n  const exportToCSV = async () => {\n    const transactions = await transactionsDB.getAll(9999);\n    const accounts = await accountsDB.getAll();\n    const credits = await creditsDB.getAll();\n    let csv = 'Typ,Kategoria,Kwota,Data,Opis,Konto\\n';\n    transactions.forEach(t => {\n      const acc = accounts.find(a => a.id === t.account_id);\n      csv += `${t.type === 'income' ? 'Przychód' : 'Wydatek'},\"${t.category}\",${t.amount},${t.date},\"${t.description || ''}\",\"${acc?.name || ''}\"\\n`;\n    });\n    csv += '\\n\\nKonta\\nNazwa,Typ,Saldo\\n';\n    accounts.forEach(a => {\n      csv += `\"${a.name}\",\"${a.type}\",${a.balance}\\n`;\n    });\n    csv += '\\n\\nKredyty\\nNazwa,Kwota całkowita,Do spłaty,Rata,Oprocentowanie\\n';\n    credits.forEach(c => {\n      csv += `\"${c.name}\",${c.total_amount},${c.remaining_amount},${c.monthly_payment},${c.interest_rate}%\\n`;\n    });\n    return csv;\n  };\n  const getDatabase = () => {\n    return {\n      initialized: true\n    };\n  };\n\n  // Full Backup Export\n  const exportFullBackup = async () => {\n    const data = {};\n    for (const [key, storageKey] of Object.entries(STORAGE_KEYS)) {\n      if (key === 'PIN_CODE' || key === 'DARK_MODE' || key === 'INITIALIZED') continue;\n      try {\n        const raw = await AsyncStorage.default.getItem(storageKey);\n        if (raw) data[key] = JSON.parse(raw);\n      } catch (e) {\n        // Skip items that can't be parsed\n      }\n    }\n    return JSON.stringify(data, null, 2);\n  };\n\n  // Full Backup Import\n  const importFullBackup = async (jsonString, mode) => {\n    const data = JSON.parse(jsonString);\n    for (const [key, storageKey] of Object.entries(STORAGE_KEYS)) {\n      if (key === 'PIN_CODE' || key === 'DARK_MODE' || key === 'INITIALIZED') continue;\n      if (!data[key]) continue;\n      if (mode === 'overwrite') {\n        await AsyncStorage.default.setItem(storageKey, JSON.stringify(data[key]));\n      } else {\n        // Append mode - merge arrays\n        const existing = await AsyncStorage.default.getItem(storageKey);\n        const existingData = existing ? JSON.parse(existing) : [];\n        if (Array.isArray(existingData) && Array.isArray(data[key])) {\n          const existingIds = new Set(existingData.map(item => item.id));\n          const newItems = data[key].filter(item => !existingIds.has(item.id));\n          await AsyncStorage.default.setItem(storageKey, JSON.stringify([...existingData, ...newItems]));\n        }\n      }\n    }\n  };\n\n  // ========== PLANS (Monthly Budget Planning) ==========\n  const plansDB = {\n    getAll: async () => {\n      const raw = await AsyncStorage.default.getItem(STORAGE_KEYS.PLANS);\n      return raw ? JSON.parse(raw) : [];\n    },\n    getByMonth: async (month, year) => {\n      const all = await plansDB.getAll();\n      return all.find(p => p.month === month && p.year === year) || null;\n    },\n    save: async plan => {\n      const all = await plansDB.getAll();\n      const idx = all.findIndex(p => p.id === plan.id);\n      if (idx >= 0) {\n        all[idx] = plan;\n      } else {\n        all.push(plan);\n      }\n      await AsyncStorage.default.setItem(STORAGE_KEYS.PLANS, JSON.stringify(all));\n      return plan;\n    },\n    createForMonth: async (month, year) => {\n      const existing = await plansDB.getByMonth(month, year);\n      if (existing) return existing;\n      const plan = {\n        id: await generateId(),\n        month,\n        year,\n        incomes: [],\n        expenses: [],\n        created_at: new Date().toISOString()\n      };\n      const all = await plansDB.getAll();\n      all.push(plan);\n      await AsyncStorage.default.setItem(STORAGE_KEYS.PLANS, JSON.stringify(all));\n      return plan;\n    },\n    addItem: async (planId, type, item) => {\n      const all = await plansDB.getAll();\n      const plan = all.find(p => p.id === planId);\n      if (!plan) return;\n      const newItem = Object.assign({}, item, {\n        id: await generateId(),\n        paid: false\n      });\n      if (type === 'income') {\n        plan.incomes.push(newItem);\n      } else {\n        plan.expenses.push(newItem);\n      }\n      await AsyncStorage.default.setItem(STORAGE_KEYS.PLANS, JSON.stringify(all));\n      return plan;\n    },\n    updateItem: async (planId, type, itemId, updates) => {\n      const all = await plansDB.getAll();\n      const plan = all.find(p => p.id === planId);\n      if (!plan) return;\n      const list = type === 'income' ? plan.incomes : plan.expenses;\n      const idx = list.findIndex(i => i.id === itemId);\n      if (idx >= 0) list[idx] = Object.assign({}, list[idx], updates);\n      await AsyncStorage.default.setItem(STORAGE_KEYS.PLANS, JSON.stringify(all));\n      return plan;\n    },\n    deleteItem: async (planId, type, itemId) => {\n      const all = await plansDB.getAll();\n      const plan = all.find(p => p.id === planId);\n      if (!plan) return;\n      if (type === 'income') {\n        plan.incomes = plan.incomes.filter(i => i.id !== itemId);\n      } else {\n        plan.expenses = plan.expenses.filter(i => i.id !== itemId);\n      }\n      await AsyncStorage.default.setItem(STORAGE_KEYS.PLANS, JSON.stringify(all));\n      return plan;\n    },\n    togglePaid: async (planId, type, itemId) => {\n      const all = await plansDB.getAll();\n      const plan = all.find(p => p.id === planId);\n      if (!plan) return;\n      const list = type === 'income' ? plan.incomes : plan.expenses;\n      const item = list.find(i => i.id === itemId);\n      if (item) item.paid = !item.paid;\n      await AsyncStorage.default.setItem(STORAGE_KEYS.PLANS, JSON.stringify(all));\n      return plan;\n    },\n    copyToMonth: async (sourcePlanId, targetMonth, targetYear) => {\n      const all = await plansDB.getAll();\n      const source = all.find(p => p.id === sourcePlanId);\n      if (!source) return null;\n\n      // Check if target already exists\n      const existingTarget = all.find(p => p.month === targetMonth && p.year === targetYear);\n      if (existingTarget) return existingTarget;\n      const newPlan = {\n        id: await generateId(),\n        month: targetMonth,\n        year: targetYear,\n        incomes: await Promise.all(source.incomes.map(async i => Object.assign({}, i, {\n          id: await generateId(),\n          paid: false\n        }))),\n        expenses: await Promise.all(source.expenses.map(async e => Object.assign({}, e, {\n          id: await generateId(),\n          paid: false\n        }))),\n        created_at: new Date().toISOString()\n      };\n      all.push(newPlan);\n      await AsyncStorage.default.setItem(STORAGE_KEYS.PLANS, JSON.stringify(all));\n      return newPlan;\n    },\n    copyToMultipleMonths: async (sourcePlanId, count) => {\n      const all = await plansDB.getAll();\n      const source = all.find(p => p.id === sourcePlanId);\n      if (!source) return;\n      for (let i = 1; i <= count; i++) {\n        let m = source.month + i;\n        let y = source.year;\n        while (m > 12) {\n          m -= 12;\n          y++;\n        }\n        const exists = all.find(p => p.month === m && p.year === y);\n        if (!exists) {\n          const newPlan = {\n            id: await generateId(),\n            month: m,\n            year: y,\n            incomes: await Promise.all(source.incomes.map(async inc => Object.assign({}, inc, {\n              id: await generateId(),\n              paid: false\n            }))),\n            expenses: await Promise.all(source.expenses.map(async exp => Object.assign({}, exp, {\n              id: await generateI